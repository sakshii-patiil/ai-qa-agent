      "id": "ed19a0df-85e6-4798-9759-d548dd5351f2",
      "name": "Aggregate Consolidate Items"
    },
    {
      "parameters": {
        "jsCode": "const rawData = $input.first().json.output || $input.first().json.text || $input.first().json.message || $input.first().json;\n\nif (typeof rawData === 'object' && rawData.testCases && Array.isArray(rawData.testCases)) {\n  return rawData.testCases.map(tc => ({ json: tc }));\n}\n\nconst raw = typeof rawData === 'string' ? rawData : JSON.stringify(rawData);\n\nfunction sanitize(s) {\n  const map = {'\\n':'\\\\n', '\\r':'\\\\r', '\\t':'\\\\t'};\n  let out = '', inStr = false, esc = false;\n  for (const ch of s) {\n    if (esc) { out += ch; esc = false; continue; }\n    if (ch === '\\\\' && inStr) { out += ch; esc = true; continue; }\n    if (ch === '\"') { inStr = !inStr; out += ch; continue; }\n    out += (inStr && map[ch]) ? map[ch] : ch;\n  }\n  return out;\n}\n\nfunction extractArray(raw) {\n  let cleaned = raw.replace(/```json\\s*/g, '').replace(/```/g, '').trim();\n  const start = cleaned.indexOf('[');\n  if (start !== -1) {\n    let depth = 0;\n    for (let i = start; i < cleaned.length; i++) {\n      if (cleaned[i] === '[') depth++;\n      else if (cleaned[i] === ']') {\n        depth--;\n        if (depth === 0) {\n          const c = cleaned.slice(start, i + 1);\n          try { return JSON.parse(c); } catch(e) {}\n          try { return JSON.parse(sanitize(c)); } catch(e) { break; }\n        }\n      }\n    }\n  }\n  const matches = (cleaned.match(/\\[[\\s\\S]*\\]/g) || []).sort((a, b) => b.length - a.length);\n  for (const m of matches) {\n    try { return JSON.parse(m); } catch(e) {}\n    try { return JSON.parse(sanitize(m)); } catch(e) {}\n  }\n  throw new Error('Could not extract test cases. Raw: ' + raw.slice(0, 200));\n}\n\nconst testCases = extractArray(raw);\n\nconst clean = testCases.map(tc => {\n  const fixed = {};\n  for (const [k, v] of Object.entries(tc)) {\n    if (typeof v === 'string') {\n      fixed[k] = v\n        .replace(/\\[([^\\]]+)\\]\\([^)]+\\)/g, '$1')  // strip [text](url)\n        .replace(/\\[([^\\]]+)\\]\\([^)]+\\)/g, '$1');  // second pass for nested\n    } else if (typeof v === 'object' && v !== null) {\n      // Convert objects (like test_data) to a readable string for Google Sheets\n      fixed[k] = Object.entries(v).map(([key, val]) => `${key}: ${val}`).join(', ');\n    } else {\n      fixed[k] = v;\n    }\n  }\n  return fixed;\n});\n\nreturn clean.map(tc => ({ json: tc }));"
      },
      "id": "b873209e-a7b7-4764-80a2-c104e2e3f479",
      "name": "Parse Clean AI Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        736,
        400
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a senior QA engineer.\n\nTICKET ID: {{ $json.key }}\nSUMMARY: {{ $json.Summary }}\nDESCRIPTION: {{ $json.Description }}\nPRIORITY: {{ $json.Priority.name }}\nACCEPTANCE CRITERIA: {{ $json['Sub-tasks'][0].fields.summary || 'Not provided - infer from description' }}\n\nDEPTH RULES based on priority:\n- High priority: generate 20 test cases, include extensive edge cases and boundary conditions\n- Medium priority: generate 15 test cases, standard coverage\n- Low priority: generate 10 test cases, happy path and key negative cases only\n\nFEATURE TYPE DETECTION — read the summary and description, then apply the matching template:\n- If UI/frontend feature: focus on visual behavior, form validation, navigation, error messages, empty states\n- If API/backend feature: focus on status codes, request/response payloads, authentication, invalid inputs, rate limits\n- If mobile feature: add touch interactions, screen orientation, offline mode, push notifications\n- If accessibility feature: add screen reader behavior, keyboard navigation, color contrast, focus management\n- If mixed: combine relevant cases from each type\n\nMODULE DETECTION — infer the module from the summary if not explicitly stated.\n\nIf Acceptance Criteria is missing, generate test cases based on the description and note your assumptions in the preconditions field.\n\nReturn ONLY a raw JSON array. Nothing before [. Nothing after ].\nEach object must have exactly: id, title, module, suite, preconditions, steps, expected_result, test_data, test_type, priority, status",
        "options": {
          "systemMessage": "Never use markdown links like [text](url) in any field. \nWrite plain text only. Use a period to end a sentence, \nthen start the next sentence normally."
        }
      },
      "id": "5b39e133-f43c-42c2-8d8c-504999c9330c",
      "name": "AI Test Generation",
